# Gateway
GATEWAY_PORT=43111
GATEWAY_HOST=0.0.0.0
GATEWAY_DATA_DIR=.local-data/gateway
# Optional: point the desktop install page at a built Android APK.
# GATEWAY_ANDROID_APK_PATH=apps/mobile/android/app/build/outputs/apk/debug/app-debug.apk

# Desktop host
DESKTOP_GATEWAY_URL=http://127.0.0.1:43111
DESKTOP_HOST_NAME=Workstation Main
DESKTOP_APPROVED_ROOTS=/absolute/path/to/approved/root
DESKTOP_DATA_DIR=.local-data/desktop
CODEX_APP_SERVER_URL=ws://127.0.0.1:43213
# Optional: override this if Adam Connect cannot find the Codex CLI automatically.
# CODEX_BIN=/full/path/to/codex
CODEX_BIN=codex

# Mobile
# The mobile app stores the paired desktop URL on-device after pairing.
