# Gateway
GATEWAY_PORT=43111
GATEWAY_HOST=0.0.0.0
GATEWAY_DATA_DIR=.local-data/gateway
# Optional: point the desktop install page at a built Android APK.
# GATEWAY_ANDROID_APK_PATH=apps/mobile/android/app/build/outputs/apk/debug/app-debug.apk

# Desktop host
DESKTOP_GATEWAY_URL=http://127.0.0.1:43111
DESKTOP_HOST_NAME=Workstation Main
DESKTOP_APPROVED_ROOTS=/absolute/path/to/approved/root
DESKTOP_DATA_DIR=.local-data/desktop
CODEX_APP_SERVER_URL=ws://127.0.0.1:43213
# Optional: override this if Adam Connect cannot find the Codex CLI automatically.
# CODEX_BIN=/full/path/to/codex
CODEX_BIN=codex

# Mobile
# The mobile app stores the paired desktop URL on-device after pairing.
# MOBILE_DEFAULT_BASE_URL=http://your-desktop.tailnet-name:43111
# MOBILE_VOICE_SESSION_ENABLED=true
# MOBILE_VOICE_INTERRUPT_MIN_CHARS=8
# MOBILE_VOICE_BACKCHANNEL_MAX_WORDS=2
# MOBILE_VOICE_TTS_MIN_CHARS=72

# Wake relay
# Run `npm run dev:wake-relay` on an always-on LAN node and point the desktop gateway at it.
# WAKE_RELAY_BASE_URL=http://raspberrypi.tailnet-name:43112
# WAKE_RELAY_TOKEN=replace-with-a-long-random-token
# WAKE_RELAY_TARGET_ID=workstation-main
# WAKE_RELAY_TARGET_LABEL=Workstation Main
# WAKE_RELAY_TARGETS_JSON=[{"id":"workstation-main","label":"Workstation Main","macAddress":"AA:BB:CC:DD:EE:FF","host":"192.168.1.25","pingPort":43111,"broadcastAddress":"192.168.1.255"}]
# WAKE_RELAY_PORT=43112
# WAKE_RELAY_HOST=0.0.0.0
# WAKE_RELAY_TIMEOUT_MS=45000
# WAKE_RELAY_POLL_INTERVAL_MS=3000
# WAKE_RELAY_WOL_PORT=9
# WAKE_RELAY_BROADCAST_ADDRESS=255.255.255.255

# Outbound email
# Verify your domain with Resend and use the verified address below as the sender.
# OUTBOUND_EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# OUTBOUND_EMAIL_FROM=freedom@agoperations.ca
# OUTBOUND_EMAIL_REPLY_TO=freedom@agoperations.ca
